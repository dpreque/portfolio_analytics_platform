# Copy to `.env` (gitignored) and fill in your PostgreSQL credentials.
# src/db/connection.py auto-loads this; real env vars override it.
PGHOST=localhost
PGPORT=5432
PGDATABASE=analytics
PGUSER=postgres
PGPASSWORD=
# Or use a single URL instead of the PG* vars:
# DATABASE_URL=postgresql://user:pass@localhost:5432/analytics
